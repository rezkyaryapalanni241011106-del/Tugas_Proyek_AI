# ============================================================
# Konfigurasi AI Code Review Tutor
#
# CARA SETUP (lakukan sekali saat pertama kali):
#   1. Salin file ini menjadi .env  (atau biarkan run.bat/run.ps1 melakukannya)
#   2. Pilih penyedia LLM di LLM_PROVIDER
#   3. Isi API key penyedia tersebut
#
# Tanpa API key: aplikasi TETAP berjalan — penjelasan AI diganti penjelasan
# umum (fallback) yang sudah disiapkan untuk setiap rule.
# ============================================================

# ── Penyedia LLM aktif ──────────────────────────────────────
# Pilih SALAH SATU: groq | openai | gemini | claude | deepseek
# (default: groq bila dikosongkan)
LLM_PROVIDER=groq

# ── (Opsional) Override model penyedia aktif ────────────────
# Kosongkan untuk memakai model default tiap penyedia:
#   groq     → llama-3.3-70b-versatile
#   openai   → gpt-4o-mini
#   gemini   → gemini-2.0-flash
#   claude   → claude-3-5-haiku-latest
#   deepseek → deepseek-chat
LLM_MODEL=

# ============================================================
# API KEY per penyedia — cukup isi key untuk penyedia yang dipakai
# ============================================================

# GROQ (GRATIS) — https://console.groq.com → API Keys → Create API Key
# Key dimulai dengan "gsk_..."
GROQ_API_KEY=

# OpenAI / ChatGPT — https://platform.openai.com/api-keys
# Key dimulai dengan "sk-..."
OPENAI_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Anthropic Claude — https://console.anthropic.com/settings/keys
# Key dimulai dengan "sk-ant-..."
ANTHROPIC_API_KEY=

# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
