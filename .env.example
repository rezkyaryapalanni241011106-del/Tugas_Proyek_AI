# Penyedia LLM aktif: groq | openai | gemini | claude | deepseek
LLM_PROVIDER=groq

# (Opsional) override model; kosongkan untuk default tiap penyedia
LLM_MODEL=

# Isi HANYA key untuk penyedia yang dipakai di atas.
# Groq gratis → daftar di https://console.groq.com
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
